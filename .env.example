# ==========================================
# HireFlow ATS - Environment Configuration
# ==========================================

# Port to run the Express backend & Vite dev server (Must be 3000 in sandbox, can be any port locally)
PORT=3000

# Secret key used for signing JWT tokens. Change this to a secure random string in production!
JWT_SECRET=ats-system-development-secret-key-9988

# Optional: Google Gemini API Key for AI-powered resume parsing.
# If omitted, HireFlow will automatically use its high-fidelity local regex-based resume parser fallback.
GEMINI_API_KEY=
